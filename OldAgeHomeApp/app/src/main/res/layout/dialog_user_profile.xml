<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Close button at top right -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            
            <ImageView
                android:id="@+id/btnDialogClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/text_grey"
                android:layout_alignParentEnd="true"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Close" />
        </RelativeLayout>

        <!-- Common Header Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="2dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/brand_start"
            app:cardBackgroundColor="@android:color/transparent"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/ivDialogAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_avatar_placeholder"
                android:scaleType="centerCrop"
                android:contentDescription="User Avatar" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvDialogName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvDialogRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resident"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_gradient"
            android:backgroundTint="@color/brand_secondary"
            android:paddingHorizontal="10dp"
            android:paddingVertical="2dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp" />

        <!-- Navigation Tabs Selector Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:background="#05000000"
            android:padding="4dp">

            <!-- Personal Tab Button -->
            <LinearLayout
                android:id="@+id/btnTabPersonal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackground">
                
                <TextView
                    android:id="@+id/tvTabPersonalText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_start" />
                <View
                    android:id="@+id/indicatorPersonal"
                    android:layout_width="32dp"
                    android:layout_height="2dp"
                    android:background="@color/brand_start"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Notifications Tab Button -->
            <LinearLayout
                android:id="@+id/btnTabNotifications"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackground">
                
                <TextView
                    android:id="@+id/tvTabNotificationsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alerts"
                    android:textSize="13sp"
                    android:textColor="@color/text_grey" />
                <View
                    android:id="@+id/indicatorNotifications"
                    android:layout_width="32dp"
                    android:layout_height="2dp"
                    android:background="@android:color/transparent"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- About Tab Button -->
            <LinearLayout
                android:id="@+id/btnTabAbout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackground">
                
                <TextView
                    android:id="@+id/tvTabAboutText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About"
                    android:textSize="13sp"
                    android:textColor="@color/text_grey" />
                <View
                    android:id="@+id/indicatorAbout"
                    android:layout_width="32dp"
                    android:layout_height="2dp"
                    android:background="@android:color/transparent"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Sections Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <!-- Section 1: Personal Details -->
            <LinearLayout
                android:id="@+id/layoutSectionPersonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Email Detail Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_dialog_email"
                        app:tint="@color/brand_start" />
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email Address"
                            android:textSize="12sp"
                            android:textColor="@color/text_grey" />
                        
                        <TextView
                            android:id="@+id/tvDialogEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="user@example.com"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#10000000" />

                <!-- Age Detail Row -->
                <LinearLayout
                    android:id="@+id/layoutDialogAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        app:tint="@color/brand_start" />
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Age"
                            android:textSize="12sp"
                            android:textColor="@color/text_grey" />
                        
                        <TextView
                            android:id="@+id/tvDialogAge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/dividerDialogAge"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#10000000" />

                <!-- Community Name Row -->
                <LinearLayout
                    android:id="@+id/layoutDialogCommunity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/brand_start" />
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Community Name"
                            android:textSize="12sp"
                            android:textColor="@color/text_grey" />
                        
                        <TextView
                            android:id="@+id/tvDialogCommunityName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/dividerDialogCommunity"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#10000000" />

                <!-- Community Code Row -->
                <LinearLayout
                    android:id="@+id/layoutDialogCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/brand_start" />
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Community Code"
                            android:textSize="12sp"
                            android:textColor="@color/text_grey" />
                        
                        <TextView
                            android:id="@+id/tvDialogCommunityCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btnCopyCode"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_save"
                        android:padding="8dp"
                        app:tint="@color/brand_start"
                        android:background="?selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Copy Code" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section 2: Notifications Settings -->
            <LinearLayout
                android:id="@+id/layoutSectionNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Notification Preferences"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Control how and when you receive reminders for medicine schedules, dosage warnings, and upcoming doctor appointments."
                    android:textSize="13sp"
                    android:textColor="@color/text_grey"
                    android:layout_marginBottom="20dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp">
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_lock_silent_mode_off"
                        app:tint="@color/brand_start" />
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reminders"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Push notifications on this device"
                            android:textSize="11sp"
                            android:textColor="@color/text_grey" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

            </LinearLayout>

            <!-- Section 3: About App -->
            <LinearLayout
                android:id="@+id/layoutSectionAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:paddingVertical="10dp">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/app_logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Serenity Haven"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Version 1.0.0"
                    android:textSize="12sp"
                    android:textColor="@color/text_grey"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Serenity Haven is a caregiver and elder care management application providing real-time scheduling, medicine alerts, smart AI assistance, and deep-link communication tools for residential facilities and personal care use."
                    android:textSize="12sp"
                    android:textColor="@color/text_grey"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:lineSpacingMultiplier="1.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="© 2026 Serenity Haven Team"
                    android:textSize="11sp"
                    android:textColor="@color/text_grey"
                    android:layout_marginTop="16dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Logout Action Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDialogLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Log Out of Account"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/bg_btn_red"
            android:elevation="2dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
