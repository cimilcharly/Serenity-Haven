<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_btn_gradient"
    android:backgroundTint="@color/white"
    android:padding="24dp">

    <!-- Bottom Sheet Drag Handle Indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#D1D5DB"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Image and Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_btn_gradient"
            android:backgroundTint="#05000000"
            android:padding="8dp">

            <ImageView
                android:id="@+id/ivDetailImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="Medicine Image" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="20dp">

            <TextView
                android:id="@+id/tvDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crocin Pain Relief"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <TextView
                android:id="@+id/tvDetailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pain Relief"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_gradient"
                android:backgroundTint="@color/brand_start"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Price Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Best Price:"
            android:textSize="15sp"
            android:textColor="@color/text_grey" />

        <TextView
            android:id="@+id/tvDetailPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹38"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/brand_secondary"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvDetailDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Contains Paracetamol &amp; Caffeine for fast relief from headache and body pain."
        android:textSize="14sp"
        android:textColor="@color/text_grey"
        android:lineSpacingMultiplier="1.2"
        android:layout_marginBottom="20dp" />

    <!-- Safety Warning Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_btn_gradient"
        android:backgroundTint="#08FF8A65"
        android:padding="12dp"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="@color/brand_secondary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Safety &amp; Usage Tip"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/brand_secondary" />

            <TextView
                android:id="@+id/tvDetailSafetyTip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Avoid taking with other paracetamol-containing medicines. Limiting alcohol is advised."
                android:textSize="12sp"
                android:textColor="@color/text_grey"
                android:layout_marginTop="2dp"
                android:lineSpacingMultiplier="1.1" />
        </LinearLayout>
    </LinearLayout>

    <!-- Buy Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnDetailBuy"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Compare Prices &amp; Buy Now"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:background="@drawable/bg_btn_gradient"
        android:elevation="4dp" />

</LinearLayout>
