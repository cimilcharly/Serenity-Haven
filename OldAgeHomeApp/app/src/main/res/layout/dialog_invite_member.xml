<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Invite New Member"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/brand_start"
            android:layout_marginBottom="8dp" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Invite members to join your community directly. You can send a direct email or share the invitation link via WhatsApp, Telegram, etc."
            android:textSize="14sp"
            android:textColor="@color/text_grey"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="20dp" />

        <!-- Email Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email Address"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/brand_start"
            app:hintTextColor="@color/brand_start"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etInviteEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_dark"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Note Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Invitation Note (Optional)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/brand_start"
            app:hintTextColor="@color/brand_start"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etInviteNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:lines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Button Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Cancel"
                android:textSize="14sp"
                android:textColor="@color/text_grey"
                android:background="@android:color/transparent"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="12dp"
                android:textAllCaps="false"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnShareLink"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Share Link"
                android:textSize="14sp"
                android:textColor="@color/brand_secondary"
                android:background="@android:color/transparent"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="12dp"
                android:textAllCaps="false"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSendEmail"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Send Email"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_gradient"
                android:paddingHorizontal="16dp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:elevation="2dp" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
