<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvDialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add New Medicine"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp" />

            <!-- Medicine Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Medicine Name"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/brand_start"
                android:layout_marginBottom="16dp">

                <AutoCompleteTextView
                    android:id="@+id/etMedicineName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dosage Details Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dosage Details"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="8dp" />

            <!-- Dosage Value Input Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Dosage Value (e.g. 500, 10, 1)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/brand_start">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDosageValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Up and Down buttons vertical stack -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <ImageButton
                        android:id="@+id/btnDosageUp"
                        android:layout_width="40dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_arrow_up"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Increase dosage"
                        android:scaleType="fitCenter"/>

                    <ImageButton
                        android:id="@+id/btnDosageDown"
                        android:layout_width="40dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_arrow_down"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Decrease dosage"
                        android:scaleType="fitCenter"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Unit Chips -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupUnit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:checkedChip="@+id/chipTablet"
                android:layout_marginBottom="16dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTablet"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tablets"
                    app:chipBackgroundColor="@color/chip_tablet_bg"
                    android:textColor="@color/chip_tablet_text"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/chip_tablet_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCapsule"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Capsules"
                    app:chipBackgroundColor="@color/chip_capsule_bg"
                    android:textColor="@color/chip_capsule_text"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/chip_capsule_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMl"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ml"
                    app:chipBackgroundColor="@color/chip_ml_bg"
                    android:textColor="@color/chip_ml_text"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/chip_ml_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMg"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mg"
                    app:chipBackgroundColor="@color/chip_mg_bg"
                    android:textColor="@color/chip_mg_text"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/chip_mg_text" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Total Stock Quantity Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Total Stock Quantity (e.g. 30)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/brand_start">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etQuantity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Up and Down buttons vertical stack -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <ImageButton
                        android:id="@+id/btnQtyUp"
                        android:layout_width="40dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_arrow_up"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Increase quantity"
                        android:scaleType="fitCenter"/>

                    <ImageButton
                        android:id="@+id/btnQtyDown"
                        android:layout_width="40dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_arrow_down"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Decrease quantity"
                        android:scaleType="fitCenter"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Reminder Times Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reminder Times"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="8dp" />

            <!-- Time Slots Container -->
            <LinearLayout
                android:id="@+id/timeSlotsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp" />

            <!-- Add Time Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAddTime"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="+ Add Reminder Time"
                android:textColor="@color/brand_start"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_gradient"
                android:backgroundTint="#1500BCD4"
                android:layout_marginBottom="24dp"
                android:elevation="0dp" />

            <!-- Actions Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Cancel Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textColor="@color/text_grey"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_btn_gradient"
                    android:backgroundTint="#10000000"
                    android:layout_marginEnd="8dp" />

                <!-- Save Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Save Medicine"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_btn_gradient"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>